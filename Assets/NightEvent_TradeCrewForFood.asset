  titleZH: "\u62FF\u4EBA\u63DB\u98DF\u7269"
  titleEN: Trade Crew for Food
  descriptionZH: "\u5CF6\u4E0A\u571F\u8457\u9858\u610F\u7528\u5927\u91CF\u98DF\u7269\u63DB\u53D6\u4E00\u540D\u8239\u54E1\u5B9A\u5C45\uFF0C\u8AAA\u662F\u300C\u806F\u59FB\u300D\u3002\n\n[\u540C\u610F]
